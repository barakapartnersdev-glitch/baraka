# انسخ هذا الملف إلى .env ثم عدّل القيم
# DATABASE_URL: اتصال زمن التشغيل — على Vercel/Neon استخدم السلسلة المجمّعة (تحتوي -pooler)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/baraka_partners?schema=public"
# DIRECT_URL: اتصال مباشر للهجرات (prisma migrate) — السلسلة المباشرة (بدون -pooler)
# محليّاً اجعله نفس DATABASE_URL. مطلوب دائماً لأن المخطط يعرّف directUrl.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/baraka_partners?schema=public"

# سرّ توقيع الجلسات — استبدله بقيمة عشوائية طويلة (32 حرفاً فأكثر)
# توليد قيمة: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-secret-value"

# ===== تخزين الملفات (اختياري — متوافق مع S3) =====
# إن تُركت هذه المفاتيح فارغة تُخزَّن الملفات محليّاً في .local-storage (مناسب للتطوير).
# للإنتاج: يعمل مع AWS S3 أو Cloudflare R2 أو MinIO. لمزوّد غير AWS اضبط S3_ENDPOINT.
# LOCAL_STORAGE_DIR=""   # مسار مخصّص للتخزين المحلي (الافتراضي .local-storage)
S3_REGION="auto"
S3_BUCKET="baraka-files"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
# اتركه فارغاً مع AWS S3؛ لـ Cloudflare R2 مثلاً:
# https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=""

# ===== البريد الإلكتروني (اختياري) =====
# إن تُركت فارغة، تُسجَّل الرسائل في السجل فقط (لا إرسال). الإشعارات الداخلية تعمل دائماً.
# المزوّد الافتراضي Resend (عبر HTTP). لتبديله عدّل src/lib/email.ts.
# RESEND_API_KEY=""
# EMAIL_FROM="شركاء البركة <no-reply@yourdomain.com>"

# الرابط الأساسي المستخدَم في روابط البريد
APP_BASE_URL="http://localhost:3000"

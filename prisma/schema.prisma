// مخطط قاعدة بيانات منصة شركاء البركة (BarakaPartners)
// يغطي الكيانات الأساسية التي تشغّل لوحة الإدارة ومنطق الحوكمة.
// قابل للتوسعة لبقية الكيانات (الرسائل، سجل النشاط، محتوى الموقع... إلخ).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // اتصال زمن التشغيل — على Vercel استخدم سلسلة Neon المجمّعة (تحتوي -pooler)
  url       = env("DATABASE_URL")
  // اتصال مباشر للهجرات (prisma migrate) — سلسلة Neon المباشرة (بدون -pooler)
  directUrl = env("DIRECT_URL")
}

// ===== المستخدمون والأدوار =====
enum UserRole {
  ADMIN // مدير المنصة (عهد البركة)
  PROJECT_OWNER // صاحب المشروع
  INVESTOR // المستثمر
  AMBASSADOR // سفير استثمار (يرشّح مستثمرين بعد اعتماد الإدارة وتوقيع العقد)
  ASSET_OWNER_AGENT // وكيل صاحب الأصل (يُفعَّل بعد اعتماد طلبه)
}

// دور فرعي داخل الإدارة (يُطبَّق فقط على role=ADMIN) — يحدّد الصلاحيات الدقيقة.
// null يُعامَل كـ SUPER_ADMIN (توافق رجعي مع نموذج الأدمن الموحّد السابق).
enum AdminRole {
  SUPER_ADMIN // كل الصلاحيات
  ADMIN // مراجعة الطلبات والترشيحات والرسائل والتقارير
  AMBASSADOR_MANAGER // إدارة السفراء والترشيحات والرسائل
  LEGAL_MANAGER // العقود والتوقيع
  STAFF // اطّلاع محدود
}

enum AccountStatus {
  PENDING_EMAIL // بانتظار تفعيل البريد
  PENDING_REVIEW // بانتظار توثيق ومراجعة الإدارة
  ACTIVE // مفعّل
  SUSPENDED // موقوف
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  fullName      String
  phone         String?
  role          UserRole
  adminRole     AdminRole? // دور فرعي للإدارة (لمستخدمي ADMIN فقط)
  accountStatus AccountStatus @default(PENDING_EMAIL)
  passwordHash  String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // العلاقات
  ownedOpportunities Opportunity[]    @relation("OwnerOpportunities")
  investorEntities   InvestorEntity[]
  interests          Interest[]
  reviewedOpps       Opportunity[]    @relation("ReviewerOpportunities")
  activityLogs       ActivityLog[]
  notifications      Notification[]

  // علاقات الـ CRM (إدارة العلاقات)
  crmAssignedLeads   CrmLead[]        @relation("CrmAssignee")
  crmAssignedByLeads CrmLead[]        @relation("CrmAssigner")
  crmNotes           CrmNote[]
  crmFollowups       CrmFollowup[]
  crmFiles           CrmFile[]
  crmActivityLogs    CrmActivityLog[]

  // علاقات سفراء الاستثمار
  ambApplicationsAssigned AmbassadorApplication[]  @relation("AmbApplicationAssignee")
  ambassadorAccount       AmbassadorAccount?       @relation("AmbAccountUser")
  ambAccountsManaged      AmbassadorAccount[]      @relation("AmbAccountManager")
  ambReferrals            AmbassadorReferral[]     @relation("AmbReferralAmbassador")
  ambReferralsAssigned    AmbassadorReferral[]     @relation("AmbReferralAssignee")
  ambMessages             AmbassadorMessage[]      @relation("AmbMessageAmbassador")
  ambMessagesCreated      AmbassadorMessage[]      @relation("AmbMessageCreator")
  ambMessageReplies       AmbassadorMessageReply[]
  ambFilesOwned           AmbassadorFile[]         @relation("AmbFileOwner")
  ambFilesUploaded        AmbassadorFile[]         @relation("AmbFileUploader")
  ambActivityAsSubject    AmbassadorActivityLog[]  @relation("AmbActivitySubject")
  ambActivityAsActor      AmbassadorActivityLog[]  @relation("AmbActivityActor")

  // وكلاء أصحاب الأصول
  assetAgentAppsAssigned    AssetAgentApplication[]    @relation("AssetAgentAppAssignee")
  assetAgentApplication     AssetAgentApplication?     @relation("AssetAgentUser")
  assetAgentAccount         AssetAgentAccount?         @relation("AssetAgentAccountUser")
  assetAgentAccountsManaged AssetAgentAccount[]        @relation("AssetAgentAccountManager")
  assetAgentSubmissions     AssetAgentSubmittedAsset[] @relation("AssetAgentSubmitter")
  assetAgentSubsAssigned    AssetAgentSubmittedAsset[] @relation("AssetAgentSubAssignee")
  assetAgentMessages        AssetAgentMessage[]        @relation("AssetAgentMsgAgent")
  assetAgentMsgReplies      AssetAgentMessageReply[]

  @@index([role])
  @@index([accountStatus])
}

// ===== سجل النشاط (التدقيق) =====
// يسجّل كل إجراء إداري حسّاس: من فعل ماذا، على أي كيان، ومتى.
model ActivityLog {
  id         String   @id @default(cuid())
  actor      User     @relation(fields: [actorId], references: [id])
  actorId    String
  action     String // نوع الإجراء، مثل: OPP_STATE_CHANGE, VERSION_SAVED, INTEREST_APPROVED
  entityType String // الكيان المتأثّر: Opportunity / Interest / MissingItem ...
  entityId   String
  details    Json? // تفاصيل إضافية (من حالة إلى حالة، إلخ)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// كيان استثماري يملكه مستثمر (يمكن للمستثمر امتلاك أكثر من كيان/شركة)
model InvestorEntity {
  id                 String     @id @default(cuid())
  name               String
  type               String // فرد / شركة / صندوق
  country            String?
  // ملف التوثيق والاستثمار (KYC + تفضيلات المطابقة) — سرّي للإدارة فقط، لا يُكشف لأصحاب المشاريع
  profile            Json?
  profileSubmittedAt DateTime?
  investor           User       @relation(fields: [investorId], references: [id])
  investorId         String
  interests          Interest[]
  createdAt          DateTime   @default(now())

  @@index([investorId])
}

// ===== الفرص الاستثمارية =====
// الحالات تعكس رحلة الحوكمة من بيانات المصدر حتى النشر.
enum OpportunityState {
  DRAFT_SOURCE // مسودة بيانات المصدر (صاحب المشروع)
  SUBMITTED // مُرسلة للإدارة
  UNDER_REVIEW // قيد مراجعة الإدارة
  NEEDS_INFO // بانتظار استكمال نواقص
  READY_TO_PUBLISH // جاهزة للنشر (اعتمدت النسخ)
  PUBLISHED // منشورة
  PAUSED // موقوفة مؤقتاً
  CLOSED // مغلقة
  ARCHIVED // مؤرشفة
}

model Opportunity {
  id      String           @id @default(cuid())
  title   String // عنوان داخلي (مرجع الإدارة)
  sector  String
  country String
  state   OpportunityState @default(DRAFT_SOURCE)

  // مالك المشروع
  owner   User   @relation("OwnerOpportunities", fields: [ownerId], references: [id])
  ownerId String

  // مراجع الإدارة (اختياري)
  reviewer   User?   @relation("ReviewerOpportunities", fields: [reviewerId], references: [id])
  reviewerId String?

  // بيانات المصدر — للإدارة فقط، لا تُنشر أبداً كما هي
  sourceData Json?

  // النسخ الثلاث للنشر (تصوغها الإدارة)
  publicVersion    Json? // النسخة العامة (للزائر)
  investorVersion  Json? // نسخة المستثمر المسجل قبل NCNDA
  postNcndaVersion Json? // نسخة ما بعد توقيع NCNDA

  // مبلغ الاستثمار المطلوب (نطاق)
  investmentMin BigInt?
  investmentMax BigInt?
  currency      String  @default("USD")

  missingItems MissingItem[]
  files        OpportunityFile[]
  interests    Interest[]
  crmLeads     CrmLead[] // طلبات الاهتمام العامة (CRM) المرتبطة بهذه الفرصة
  assetAgentSubmission AssetAgentSubmittedAsset? @relation("AssetAgentConvertedOpp") // أصل وكيل حُوِّل لهذه الفرصة

  // وجهة الاستثمار المرتبطة (اختياري) — تُعرض الفرصة ضمن صفحة الدولة المطابقة
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  destinationId String?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([state])
  @@index([sector])
  @@index([destinationId])
}

// النواقص التي تطلبها الإدارة من صاحب المشروع
model MissingItem {
  id            String      @id @default(cuid())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String
  description   String
  resolved      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([opportunityId])
}

// ملفات الفرصة (تخزّن مرجعاً آمناً + مستوى الإتاحة)
enum FileVisibility {
  ADMIN_ONLY // للإدارة فقط
  POST_NCNDA // تظهر بعد توقيع NCNDA
}

model OpportunityFile {
  id            String         @id @default(cuid())
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String
  fileName      String
  storageKey    String // مرجع التخزين الآمن
  visibility    FileVisibility @default(ADMIN_ONLY)
  approved      Boolean        @default(false) // معتمد من الإدارة
  createdAt     DateTime       @default(now())

  @@index([opportunityId])
}

// ===== طلبات الاهتمام و NCNDA =====
enum InterestStatus {
  REQUESTED // طلب اهتمام جديد
  ADMIN_APPROVED // اعتمدته الإدارة (يحق له التوقيع)
  NCNDA_SIGNED // وقّع NCNDA — تُفتح تفاصيل ما بعد التوقيع
  DECLINED // مرفوض
  WITHDRAWN // مسحوب
}

model Interest {
  id              String          @id @default(cuid())
  opportunity     Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId   String
  investor        User            @relation(fields: [investorId], references: [id])
  investorId      String
  entity          InvestorEntity? @relation(fields: [entityId], references: [id])
  entityId        String?
  status          InterestStatus  @default(REQUESTED)
  ncndaSignedAt   DateTime?
  ncndaSignerName String? // الاسم المكتوب كتوقيع
  ncndaDocKey     String? // مفتاح تخزين نسخة الاتفاقية الموقّعة
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([opportunityId, investorId])
  @@index([status])
}

// ===== الإشعارات داخل المنصة =====
enum NotificationType {
  NEW_REGISTRATION // للإدارة: تسجيل مستثمر جديد
  ACCOUNT_APPROVED // للمستخدم: اعتُمد حسابه
  ACCOUNT_SUSPENDED // للمستخدم: أُوقف حسابه
  INTEREST_REQUESTED // للإدارة: طلب اهتمام جديد
  INTEREST_APPROVED // للمستثمر: اعتُمد طلبه
  INTEREST_DECLINED // للمستثمر: رُفض طلبه
  NCNDA_SIGNED // متعلّق بتوقيع NCNDA
  MISSING_INFO_REQUESTED // لصاحب المشروع: طُلبت نواقص
  OPPORTUNITY_PUBLISHED // لصاحب المشروع: نُشرت فرصته
  OPPORTUNITY_STATE_CHANGED // لصاحب المشروع: تغيّرت حالة فرصته
  NEW_CRM_LEAD // للإدارة: طلب/رسالة جديدة من نماذج الموقع (CRM)
  CRM_LEAD_ASSIGNED // للموظف: أُسند إليه طلب في الـ CRM
  // ===== سفراء الاستثمار =====
  AMBASSADOR_APPLICATION_RECEIVED // للإدارة: طلب انضمام سفير جديد
  AMBASSADOR_STATUS_CHANGED // للمتقدم/السفير: تغيّرت حالة طلبه
  AMBASSADOR_CONTRACT_SENT // للمتقدم: أُرسل العقد للتوقيع
  AMBASSADOR_CONTRACT_SIGNED // للإدارة: تم توقيع العقد
  AMBASSADOR_ACCOUNT_CREATED // للسفير: فُتح حسابه
  AMBASSADOR_NEW_MESSAGE // للطرف الآخر: رسالة داخلية جديدة
  AMBASSADOR_NEW_REFERRAL // لمدير السفراء: ترشيح مستثمر جديد
  AMBASSADOR_REFERRAL_STATUS_CHANGED // للسفير: تحديث حالة ترشيح
  // ===== وكلاء أصحاب الأصول =====
  ASSET_AGENT_APPLICATION_RECEIVED // للإدارة: طلب وكيل جديد
  ASSET_AGENT_STATUS_CHANGED // للمتقدّم/الوكيل: تغيّرت حالة طلبه
  ASSET_AGENT_CONTRACT_SENT // للمتقدّم: أُرسل العقد للتوقيع
  ASSET_AGENT_CONTRACT_SIGNED // للإدارة: تم توقيع العقد
  ASSET_AGENT_ACCOUNT_CREATED // للوكيل: فُتح حسابه
  ASSET_AGENT_NEW_MESSAGE // للطرف الآخر: رسالة داخلية جديدة
  ASSET_AGENT_NEW_ASSET // للإدارة: أصل/فرصة جديدة من وكيل
  ASSET_AGENT_ASSET_STATUS_CHANGED // للوكيل: تحديث حالة أصل مقدّم
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ===== CRM / إدارة العلاقات الاستثمارية =====
// يلتقط كل رسالة/طلب وارد من نماذج الموقع العامة (زوّار غير مسجّلين) ويحوّله
// إلى سجل قابل للتصنيف والإسناد والمتابعة. منفصل عن Interest (للمستثمر المسجّل).

// نوع الطلب — يحدّد أي نموذج أرسله ومسار متابعته
enum LeadType {
  INVESTOR_INTEREST // طلب اهتمام بفرصة استثمارية محددة
  OPPORTUNITY_SUBMISSION // تقديم فرصة استثمارية (صاحب فرصة)
  CONTACT // تواصل عام
  HOME_QUICK // نموذج الصفحة الرئيسية السريع
  INVESTMENT_AMBASSADOR_APPLICATION // طلب الانضمام كسفير استثمار
}

// مصدر الطلب — الصفحة التي أُرسل منها
enum LeadSource {
  OPPORTUNITY_PAGE
  SUBMIT_PAGE
  CONTACT_PAGE
  HOME_PAGE
  DESTINATION_PAGE // نموذج صفحة «استثمر في <دولة>» (وجهات الاستثمار)
  INVESTMENT_AMBASSADORS_PAGE // صفحة سفراء الاستثمار
}

// درجة الأهمية
enum LeadPriority {
  VERY_HIGH
  HIGH
  MEDIUM
  LOW
}

model CrmLead {
  id        String       @id @default(cuid())
  leadType  LeadType
  source    LeadSource
  // الحالة كنص (كود موحّد) — مرنة وقابلة للتوسعة من الإدارة لاحقاً؛
  // القيم المسموحة ومسارها لكل نوع معرّفة في src/lib/crm.ts
  status    String       @default("NEW")
  priority  LeadPriority @default(MEDIUM)
  leadScore Int          @default(0)

  // بيانات المرسل
  fullName         String
  email            String
  phone            String?
  whatsapp         String?
  country          String?
  city             String?
  companyName      String?
  senderRole       String? // كود موحّد: investor / broker / project_owner ...
  preferredContact String? // whatsapp / email / phone / online_meeting
  investmentBudget String? // نص حر (نطاق أو مبلغ)
  sectorInterest   String?

  // الرسالة واللغة (لا يُغيَّر النص الأصلي أبداً)
  message                String?
  languageCode           String  @default("ar") // ar / en / tr / zh
  internalTranslation    String? // ترجمة داخلية يضيفها الفريق عند الحاجة
  preferredReplyLanguage String?

  // الربط بالفرصة (لطلبات الاهتمام من صفحة فرصة)
  relatedOpportunity   Opportunity? @relation(fields: [relatedOpportunityId], references: [id])
  relatedOpportunityId String?

  // الربط بوجهة الاستثمار (لطلبات نموذج صفحة الدولة — source = DESTINATION_PAGE)
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  destinationId String?

  // حقول خاصة بتقديم فرصة استثمارية (OPPORTUNITY_SUBMISSION)
  projectSector  String?
  projectCountry String?
  projectCity    String?
  hasFeasibility String? // yes / no / in_progress
  hasLicensing   String? // yes / no / partial

  // الإسناد الداخلي
  assignedTo   User?     @relation("CrmAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  assignedBy   User?     @relation("CrmAssigner", fields: [assignedById], references: [id])
  assignedById String?
  assignedAt   DateTime?
  department   String? // كود قسم داخلي (investor_relations / opp_review / legal ...)

  // أعلام وحالة
  isRead          Boolean @default(false)
  isSpam          Boolean @default(false)
  privacyAccepted Boolean @default(false)

  // بيانات تقنية (للحماية من السبام والتدقيق)
  ipAddress String?
  userAgent String?

  lastFollowupAt DateTime? // آخر متابعة (للفرز والتنبيه على المتأخرات)

  notes        CrmNote[]
  followups    CrmFollowup[]
  files        CrmFile[]
  activityLogs CrmActivityLog[]

  // ربط بنظام سفراء الاستثمار (طلب السفير / ترشيح المستثمر يظهر كـ Lead)
  ambassadorApplications AmbassadorApplication[]
  ambassadorReferrals    AmbassadorReferral[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadType])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([relatedOpportunityId])
  @@index([destinationId])
  @@index([isRead])
  @@index([isSpam])
  @@index([languageCode])
  @@index([createdAt])
}

model CrmNote {
  id        String   @id @default(cuid())
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  // نوع الملاحظة: internal_note / call_log / whatsapp_log / email_log /
  // meeting_log / status_change / file_upload
  noteType  String   @default("internal_note")
  note      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model CrmFollowup {
  id           String   @id @default(cuid())
  lead         CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId       String
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  followupAt   DateTime
  followupType String   @default("call") // call / email / whatsapp / online_meeting / document_request / internal_review
  status       String   @default("pending") // pending / done / cancelled
  reminderSent Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([leadId])
  @@index([assignedToId])
  @@index([followupAt])
}

model CrmFile {
  id           String   @id @default(cuid())
  lead         CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId       String
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  fileName     String
  storageKey   String // مرجع التخزين الآمن (S3)
  fileType     String?
  fileSize     Int?
  visibility   String   @default("admin_only")
  createdAt    DateTime @default(now())

  @@index([leadId])
}

model CrmEmailTemplate {
  id           String   @id @default(cuid())
  templateKey  String // مثل: investor_initial_reply
  templateType String?
  languageCode String // ar / en / tr / zh
  subject      String
  body         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateKey, languageCode])
  @@index([languageCode])
}

model CrmActivityLog {
  id          String   @id @default(cuid())
  lead        CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  actor       User?    @relation(fields: [actorId], references: [id])
  actorId     String?
  actionType  String // created / status_change / priority_change / assigned / note_added / read ...
  oldValue    String?
  newValue    String?
  description String?
  createdAt   DateTime @default(now())

  @@index([leadId])
}

// ===== وجهات الاستثمار (صفحات SEO تعريفية حسب الدولة) =====
// قسم ثابت متعدّد اللغات يحسّن ظهور الموقع لعبارات «استثمر في <دولة>» ويحوّل الزائر
// إلى Lead في الـ CRM. المحتوى وSEO قابلان للتحرير بالكامل من لوحة الإدارة لكل لغة.

model Destination {
  id            String  @id @default(cuid())
  countryKey    String  @unique // مفتاح ثابت لا يتغيّر: turkey / syria / european-union / cyprus / egypt / jordan
  region        String? // تصنيف جغرافي (الشرق الأوسط، أوروبا...) — للعرض والفلترة
  flagEmoji     String? // رمز العلم (اختياري) لعرضه في البطاقات
  featuredImage String? // صورة/خلفية رئيسية (مسار عام أو رابط)
  isActive      Boolean @default(true) // تفعيل/إخفاء الصفحة بالكامل
  showInMenu    Boolean @default(true)
  showInFooter  Boolean @default(true)
  inSitemap     Boolean @default(true) // إدراج في sitemap عند التفعيل
  displayOrder  Int     @default(0) // ترتيب الظهور في القوائم والبطاقات

  translations  DestinationTranslation[]
  opportunities Opportunity[] // فرص منشورة مرتبطة بهذه الدولة
  crmLeads      CrmLead[] // طلبات واردة من نموذج صفحة الدولة

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

// محتوى وSEO صفحة الدولة لكل لغة (ar / en / tr / zh) — slug مستقل لكل لغة.
model DestinationTranslation {
  id            String      @id @default(cuid())
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  destinationId String
  locale        String // ar / en / tr / zh
  slug          String // فريد ضمن اللغة الواحدة، قابل للتعديل من الإدارة

  // ---- المحتوى (يقابل بنية الصفحة الثابتة) ----
  countryName           String? // اسم الدولة المختصر باللغة (تركيا / Turkey...) — للعناوين والمسار
  pageTitle             String? // عنوان التبويب (إن خلا يُشتقّ من seoTitle/h1)
  h1Title               String // العنوان الرئيسي H1
  introText             String? // مقدمة تعريفية
  whyInvestTitle        String?
  whyInvestPoints       Json? // string[] — نقاط «لماذا الاستثمار»
  keySectorsTitle       String?
  keySectorsList        Json? // string[] — القطاعات الواعدة
  opportunityTypesTitle String?
  opportunityTypesList  Json? // string[] — أنواع الفرص المتاحة
  investorNotesTitle    String?
  investorNotesPoints   Json? // string[] — معلومات أولية للمستثمر
  disclaimerText        String? // التنبيه القانوني
  ctaTitle              String?
  ctaDescription        String?
  ctaButtonText         String?
  faq                   Json? // {q,a}[] — أسئلة شائعة

  // ---- SEO لكل لغة ----
  seoTitle           String?
  metaDescription    String?
  focusKeyword       String?
  secondaryKeywords  Json? // string[]
  canonicalUrl       String? // تجاوز اختياري (الافتراضي يُبنى تلقائياً من APP_BASE_URL)
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  schemaJson         Json? // JSON-LD إضافي اختياري يحقنه الأدمن
  robotsIndex        Boolean @default(true)
  robotsFollow       Boolean @default(true)
  sitemapPriority    Float   @default(0.7)
  sitemapChangefreq  String  @default("monthly")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([destinationId, locale])
  @@unique([locale, slug])
  @@index([destinationId])
}

// ============================================================
// ===== سفراء الاستثمار (Investment Ambassadors) =====
// نظام فرعي متكامل: طلب انضمام عام → مراجعة وتقييم الإدارة → عقد → فتح حساب
// → بوّابة سفير يرشّح عبرها مستثمرين ويراسل الإدارة. هجرة إضافية بالكامل.
// ============================================================

// حالة طلب الانضمام كسفير (قابلة للتوسعة من الإدارة لاحقاً)
enum AmbassadorAppStatus {
  NEW // جديد
  UNDER_REVIEW // قيد المراجعة
  NEEDS_INFO // يحتاج معلومات إضافية
  INTERVIEW // قيد المقابلة
  PRE_QUALIFIED // مؤهّل مبدئياً
  NOT_QUALIFIED // غير مؤهّل
  PRE_ACCEPTED // مقبول مبدئياً
  AWAITING_CONTRACT // بانتظار توقيع العقد
  CONTRACT_SIGNED // تم توقيع العقد
  ACCOUNT_CREATED // تم فتح حساب السفير
  ACTIVE // نشط
  SUSPENDED // موقوف مؤقتاً
  REJECTED // مرفوض
  ARCHIVED // مؤرشف
}

// حالة ترشيح المستثمر من السفير
enum ReferralStatus {
  NEW // جديد
  UNDER_REVIEW // قيد المراجعة
  NEEDS_INFO // يحتاج معلومات إضافية
  PRE_QUALIFIED // مؤهّل مبدئياً
  NOT_QUALIFIED // غير مؤهّل
  INVESTOR_CONTACTED // تم التواصل مع المستثمر
  AWAITING_INVESTOR // بانتظار رد المستثمر
  MEETING_SCHEDULED // تم ترتيب اجتماع
  NEGOTIATING // قيد التفاوض
  CLOSED_WON // مغلق بنجاح
  CLOSED_LOST // مغلق بدون نتيجة
  ARCHIVED // مؤرشف
}

// حالة عقد السفير (تدعم المسارين: رفع يدوي وتوقيع إلكتروني)
enum AmbassadorContractStatus {
  NOT_SENT // لم يتم الإرسال
  SENT // تم الإرسال
  OPENED // تم الفتح
  AWAITING_SIGNATURE // بانتظار التوقيع
  SIGNED // تم التوقيع
  REJECTED // مرفوض
  EXPIRED // منتهي الصلاحية
}

// حالة الرسالة الداخلية بين السفير والإدارة
enum AmbassadorMessageStatus {
  NEW // جديد
  IN_PROGRESS // قيد الرد
  REPLIED // تم الرد
  CLOSED // مغلق
}

// طلب الانضمام كسفير استثمار (النموذج العام، 4 لغات)
model AmbassadorApplication {
  id String @id @default(cuid())

  // ----- بيانات شخصية -----
  fullName          String
  nationality       String?
  residenceCountry  String?
  city              String?
  phone             String?
  whatsapp          String?
  email             String
  preferredLanguage String? // لغة التواصل المفضّلة (ar/en/tr/zh/other)
  spokenLanguages   Json?
  photoKey          String? // صورة شخصية اختيارية (مرجع تخزين آمن)

  // ----- بيانات مهنية -----
  currentTitle      String?
  companyName       String?
  professionalRole  String?
  yearsOfExperience String?
  workType          String? // individual / company / consulting_office / brokerage / other
  website           String?
  linkedinUrl       String?
  otherLinks        String?

  // ----- شبكة العلاقات -----
  coveredCountries   Json?
  investorTypes      Json? // hnwi / investment_company / family_office / fund / holding ...
  coveredSectors     Json?
  investmentRange    String? // نطاق حجم الاستثمار الذي يصل لمستثمرين مهتمين به
  relationshipType   String? // direct / via_partners / mixed
  previousExperience String? // yes / no — سبق العمل في جذب مستثمرين
  experienceSummary  String?

  // ----- أسئلة التقييم + أي حقول إضافية -----
  motivation         String?
  addedValue         String?
  conflictOfInterest String?
  answers            Json? // بقية أسئلة التقييم الحرّة (مفتاح→قيمة)

  // ----- الموافقات الإلزامية -----
  infoAccuracyAck     Boolean @default(false) // صحة المعلومات
  privacyAccepted     Boolean @default(false) // سياسة الخصوصية
  applicationAck      Boolean @default(false) // التقديم لا يعني القبول
  noRepresentationAck Boolean @default(false) // عدم استخدام الاسم قبل الاعتماد
  contactConsent      Boolean @default(false) // الموافقة على التواصل للمراجعة

  // ----- إدارة / حوكمة -----
  status       AmbassadorAppStatus @default(NEW)
  score        Int                 @default(0)
  assignedTo   User?               @relation("AmbApplicationAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  // ----- مصدر / لغة / ربط CRM -----
  source       String   @default("investment_ambassadors_page")
  languageCode String   @default("ar")
  crmLead      CrmLead? @relation(fields: [crmLeadId], references: [id])
  crmLeadId    String?

  // ----- بيانات تقنية (حماية وتدقيق) -----
  ipAddress String?
  userAgent String?

  // ----- علاقات -----
  files     AmbassadorFile[]
  contracts AmbassadorContract[]
  account   AmbassadorAccount?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([residenceCountry])
  @@index([score])
  @@index([assignedToId])
  @@index([createdAt])
}

// ملفات السفراء (مرتبطة بطلب/سفير/ترشيح/رسالة حسب الحاجة)
model AmbassadorFile {
  id String @id @default(cuid())

  application   AmbassadorApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String?

  // ملفات «ملفاتي» داخل حساب السفير
  ambassadorUser   User?   @relation("AmbFileOwner", fields: [ambassadorUserId], references: [id])
  ambassadorUserId String?

  referral   AmbassadorReferral? @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referralId String?

  message   AmbassadorMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String?

  fileName     String
  storageKey   String // مرجع التخزين الآمن — لا يُخدم مباشرة
  fileType     String?
  fileSize     Int?
  fileCategory String? // cv / company_profile / personal_profile / work_sample / supporting / referral_doc / message_attachment / internal
  visibility   String  @default("admin_only") // admin_only / ambassador / shared

  uploadedBy   User?   @relation("AmbFileUploader", fields: [uploadedById], references: [id])
  uploadedById String?

  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([ambassadorUserId])
  @@index([referralId])
  @@index([messageId])
}

// عقد السفير — يدعم رفع PDF موقّع يدوياً أو توقيعاً إلكترونياً مدمجاً (المرحلة 3)
model AmbassadorContract {
  id String @id @default(cuid())

  application   AmbassadorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String

  // الحساب الذي يعتمد هذا العقد (علاقة 1-1 معكوسة)
  account AmbassadorAccount? @relation("AccountContract")

  templateId String? // قالب العقد المستخدم (CrmEmailTemplate أو قالب مخصّص لاحقاً)
  status     AmbassadorContractStatus @default(NOT_SENT)

  contractPdfKey String? // نسخة العقد المُرسَلة (غير موقّعة)
  signedPdfKey   String? // نسخة العقد الموقّعة

  sentAt    DateTime?
  openedAt  DateTime?
  signedAt  DateTime?
  expiresAt DateTime?

  // التوقيع الإلكتروني (المرحلة 3): DocuSign / Dropbox Sign / PandaDoc ...
  signingProvider     String?
  externalSignatureId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([status])
}

// حساب السفير المعتمد (يُفتح بعد توقيع العقد)
model AmbassadorAccount {
  id String @id @default(cuid())

  user   User   @relation("AmbAccountUser", fields: [userId], references: [id])
  userId String @unique

  application   AmbassadorApplication @relation(fields: [applicationId], references: [id])
  applicationId String                @unique

  status    String    @default("active") // active / suspended / closed
  startDate DateTime?

  allowedCountries Json? // نطاق الدول المصرّح بها
  allowedSectors   Json? // نطاق القطاعات المصرّح بها

  assignedManager   User?   @relation("AmbAccountManager", fields: [assignedManagerId], references: [id])
  assignedManagerId String?

  contract   AmbassadorContract? @relation("AccountContract", fields: [contractId], references: [id])
  contractId String?             @unique

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ترشيح مستثمر محتمل من السفير
model AmbassadorReferral {
  id String @id @default(cuid())

  ambassadorUser   User   @relation("AmbReferralAmbassador", fields: [ambassadorUserId], references: [id])
  ambassadorUserId String

  // بيانات المستثمر المرشَّح
  investorName    String
  investorCompany String?
  investorCountry String?
  investorCity    String?
  investorType    String? // individual / company / fund / family_office / holding / government / other

  interestedSectors Json?
  investmentRange   String?

  relationshipWithAmbassador String? // direct / via_third_party / initial / prior_contact
  seriousnessLevel           String? // high / medium / low
  consentConfirmed           String? // yes / no / needs_confirmation

  // بيانات التواصل (حسب ضوابط الخصوصية)
  contactEmail String?
  contactPhone String?
  linkedinUrl  String?
  website      String?

  description     String?
  ambassadorNotes String?

  // إدارة (لا يراها السفير كاملة)
  status        ReferralStatus @default(NEW)
  internalScore Int?
  assignedTo    User?          @relation("AmbReferralAssignee", fields: [assignedToId], references: [id])
  assignedToId  String?

  // ربط CRM (يظهر الترشيح كـ Investor Lead)
  crmLead   CrmLead? @relation(fields: [crmLeadId], references: [id])
  crmLeadId String?

  files AmbassadorFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ambassadorUserId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

// رسالة داخلية (محادثة) بين السفير والإدارة
model AmbassadorMessage {
  id String @id @default(cuid())

  ambassadorUser   User   @relation("AmbMessageAmbassador", fields: [ambassadorUserId], references: [id])
  ambassadorUserId String

  relatedReferralId String? // ربط اختياري بترشيح معيّن

  subject     String
  messageType String                  @default("general") // general / new_investor / file_followup / clarification / technical / other
  status      AmbassadorMessageStatus @default(NEW)

  createdBy   User?   @relation("AmbMessageCreator", fields: [createdById], references: [id])
  createdById String?

  replies AmbassadorMessageReply[]
  files   AmbassadorFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ambassadorUserId])
  @@index([status])
}

// رد ضمن محادثة داخلية
model AmbassadorMessageReply {
  id String @id @default(cuid())

  message   AmbassadorMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String

  sender       User?   @relation(fields: [senderUserId], references: [id])
  senderUserId String?
  senderRole   String? // ambassador / admin (لقطة للدور وقت الإرسال)

  body String

  createdAt DateTime @default(now())

  @@index([messageId])
}

// سجل نشاط نظام السفراء (تدقيق منفصل عن ActivityLog العام)
model AmbassadorActivityLog {
  id String @id @default(cuid())

  ambassadorUser   User?   @relation("AmbActivitySubject", fields: [ambassadorUserId], references: [id])
  ambassadorUserId String?

  relatedEntityType String? // Application / Referral / Contract / Account / Message
  relatedEntityId   String?

  actionType  String // created / status_change / score_change / assigned / note_added / contract_sent / contract_signed / account_created ...
  description String?
  oldValue    String?
  newValue    String?

  createdBy   User?   @relation("AmbActivityActor", fields: [createdById], references: [id])
  createdById String?

  createdAt DateTime @default(now())

  @@index([ambassadorUserId])
  @@index([relatedEntityType, relatedEntityId])
  @@index([createdAt])
}

// ============================================================
// ===== وكلاء أصحاب الأصول (Asset Owner Agents) =====
// توأم بنيوي لميزة السفراء — للوكلاء الذين يمثّلون أصحاب الأصول. هجرة إضافية.
// ============================================================

enum AssetAgentAppStatus {
  NEW // جديد
  UNDER_REVIEW // قيد المراجعة
  NEEDS_INFO // بحاجة إلى معلومات إضافية
  PRE_QUALIFIED // مؤهَّل مبدئياً
  REJECTED // مرفوض
  AWAITING_CONTRACT // بانتظار توقيع العقد
  CONTRACTED // تم التعاقد
  ACTIVE // حساب مفعّل
  SUSPENDED // موقوف
}

// طلب الانضمام كوكيل لصاحب أصل (النموذج العام)
model AssetAgentApplication {
  id String @id @default(cuid())

  // ----- بيانات شخصية وتواصل -----
  fullName          String
  nationality       String?
  country           String? // دولة الإقامة
  city              String?
  phone             String
  whatsapp          String?
  email             String
  preferredLanguage String  @default("ar") // ar / tr / en

  // ----- الصفة المهنية -----
  professionalType      String?
  professionalTypeOther String?

  // ----- نوع العلاقة بأصحاب الأصول -----
  relationshipType      String?
  relationshipTypeOther String?

  // ----- التغطية -----
  coveredAssetTypes      Json?
  coveredAssetTypesOther String?
  coveredRegions         Json?
  coveredRegionsOther    String?

  // ----- الخبرة -----
  experienceYears       String?
  experienceDescription String?
  hasPreviousDeals      String? // yes / no
  previousDeals         String?

  // ----- القدرة على توفير المعلومات (yes/no) -----
  canProvideInfo      String?
  canContactOwner     String?
  canArrangeMeeting   String?
  canProvideDocuments String?
  ownerWantsDeal      String?
  hasOwnerPermission  String?

  // ----- روابط مهنية -----
  linkedinUrl String?
  websiteUrl  String?
  companyUrl  String?

  // ----- الإقرارات الإلزامية -----
  infoAccuracyAck     Boolean @default(false)
  noRepresentationAck Boolean @default(false)
  privacyAccepted     Boolean @default(false)
  contactConsent      Boolean @default(false)
  ownerConsentAck     Boolean @default(false)

  // ----- إدارة / حوكمة -----
  status          AssetAgentAppStatus @default(NEW)
  score           Int                 @default(0)
  assignedTo      User?               @relation("AssetAgentAppAssignee", fields: [assignedToId], references: [id])
  assignedToId    String?
  adminNotes      String?
  rejectionReason String?
  lastContactAt   DateTime?

  // ----- مصدر / لغة / تقني -----
  source       String  @default("asset_owner_agents_page")
  languageCode String  @default("ar")
  ipAddress    String?
  userAgent    String?

  // ----- ربط الحساب (المرحلة 2) -----
  userId String? @unique // يُملأ عند تفعيل الحساب
  user   User?   @relation("AssetAgentUser", fields: [userId], references: [id])

  files     AssetAgentFile[]
  contracts AssetAgentContract[]
  account   AssetAgentAccount?
  messages  AssetAgentMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([country])
  @@index([assignedToId])
  @@index([createdAt])
}

// ملفات طلب الوكيل (سرّية — للإدارة فقط)
model AssetAgentFile {
  id            String                @id @default(cuid())
  application   AssetAgentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String

  // ربط اختياري بأصل مقدّم (المرحلة 2) + معرّف الوكيل لملفات «ملفاتي»
  submittedAsset   AssetAgentSubmittedAsset? @relation(fields: [submittedAssetId], references: [id], onDelete: Cascade)
  submittedAssetId String?
  agentUserId      String?

  fileName     String
  storageKey   String // مرجع تخزين آمن — لا يُخدَم مباشرة
  fileType     String?
  fileSize     Int?
  fileCategory String? // cv / company_profile / id / authorization / supporting / asset_doc / contract / contract_signed
  visibility   String  @default("admin_only")

  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([submittedAssetId])
  @@index([agentUserId])
}

// ===== وكلاء أصحاب الأصول — المرحلة 2 (الحساب/العقد/الأصول/المراسلات) =====

enum AssetSubmissionStatus {
  NEW_SUBMISSION // جديد
  UNDER_REVIEW // قيد المراجعة
  NEEDS_INFO // بحاجة معلومات
  PRE_QUALIFIED // مؤهَّل مبدئياً
  NOT_QUALIFIED // غير مؤهَّل
  APPROVED // معتمد (جاهز للتحويل)
  CONVERTED // حُوِّل إلى فرصة استثمارية
  REJECTED // مرفوض
  ARCHIVED // مؤرشف
}

enum AssetAgentContractStatus {
  NOT_SENT
  SENT
  OPENED
  AWAITING_SIGNATURE
  SIGNED
  REJECTED
  EXPIRED
}

enum AssetAgentMessageStatus {
  NEW
  IN_PROGRESS
  REPLIED
  CLOSED
}

// عقد الوكالة (مرآة AmbassadorContract)
model AssetAgentContract {
  id            String                @id @default(cuid())
  application   AssetAgentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String

  account AssetAgentAccount? @relation("AssetAgentAccountContract")

  status         AssetAgentContractStatus @default(NOT_SENT)
  contractPdfKey String?
  signedPdfKey   String?
  sentAt         DateTime?
  openedAt       DateTime?
  signedAt       DateTime?
  expiresAt      DateTime?

  signingProvider     String?
  externalSignatureId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([status])
}

// حساب الوكيل المعتمد (مرآة AmbassadorAccount)
model AssetAgentAccount {
  id     String @id @default(cuid())
  user   User   @relation("AssetAgentAccountUser", fields: [userId], references: [id])
  userId String @unique

  application   AssetAgentApplication @relation(fields: [applicationId], references: [id])
  applicationId String                @unique

  status    String    @default("active") // active / suspended / closed
  startDate DateTime?

  allowedAssetTypes Json?
  allowedRegions    Json?

  assignedManager   User?   @relation("AssetAgentAccountManager", fields: [assignedManagerId], references: [id])
  assignedManagerId String?

  contract   AssetAgentContract? @relation("AssetAgentAccountContract", fields: [contractId], references: [id])
  contractId String?             @unique

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// أصل/فرصة يقدّمها الوكيل (مرآة AmbassadorReferral — للأصول)
model AssetAgentSubmittedAsset {
  id          String @id @default(cuid())
  agentUser   User   @relation("AssetAgentSubmitter", fields: [agentUserId], references: [id])
  agentUserId String

  title            String
  country          String?
  city             String?
  assetType        String? // كود من ASSET_TYPES
  assetStatus      String? // operating / distressed / needs_financing / for_sale / for_partnership / for_development
  shortDescription String?
  estimatedValue   String?
  requiredFinancing String?
  offerType         String? // sale / partnership / financing / operation / restructuring

  agentRelationshipToOwner String?
  hasOwnerPermission       String? // yes / no
  hasOwnershipDocuments    String? // yes / no
  canArrangeOwnerMeeting   String? // yes / no
  additionalNotes          String?

  status       AssetSubmissionStatus @default(NEW_SUBMISSION)
  assignedTo   User?                 @relation("AssetAgentSubAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  adminNotes   String?
  rejectionReason String?

  // ربط بالفرصة بعد التحويل
  convertedOpportunity   Opportunity? @relation("AssetAgentConvertedOpp", fields: [convertedOpportunityId], references: [id], onDelete: SetNull)
  convertedOpportunityId String?      @unique

  files AssetAgentFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentUserId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

// رسالة داخلية بين الوكيل والإدارة (مرآة AmbassadorMessage)
model AssetAgentMessage {
  id            String                 @id @default(cuid())
  application   AssetAgentApplication? @relation(fields: [applicationId], references: [id])
  applicationId String?

  agentUser   User?   @relation("AssetAgentMsgAgent", fields: [agentUserId], references: [id])
  agentUserId String?

  relatedSubmittedAssetId String?

  subject     String
  messageType String                  @default("general")
  status      AssetAgentMessageStatus @default(NEW)
  createdById String?

  replies AssetAgentMessageReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([agentUserId])
  @@index([status])
}

// رد على محادثة (مرآة AmbassadorMessageReply)
model AssetAgentMessageReply {
  id        String            @id @default(cuid())
  message   AssetAgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String

  sender       User?   @relation(fields: [senderUserId], references: [id])
  senderUserId String?
  senderRole   String? // agent / admin (لقطة وقت الإرسال)

  body String

  createdAt DateTime @default(now())

  @@index([messageId])
}
